VITE_API_PROXY_TARGET=http://localhost:8080
# Leave VITE_API_BASE_URL blank for local dev so Vite can proxy /api requests.
# Set it to a full backend origin for split-host deployments, for example:
# VITE_API_BASE_URL=https://api.example.com

# Optional base path when the SPA is deployed under a sub-path such as /asset-management/
VITE_APP_BASE_PATH=/
